# Copy this file to .env and fill in your real keys.
# Do not commit .env with real secrets.

# Required for core chat + embeddings (used by LangChain OpenAI clients)
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-5-mini

# Optional: enables Tavily web research worker
TAVILY_API_KEY=

# Optional: enables Gemini image generation.
# You can set either GOOGLE_API_KEY or GEMINI_API_KEY.
GOOGLE_API_KEY=
# GEMINI_API_KEY=
